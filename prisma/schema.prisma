generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./weather.db"
}

model SearchLog {
  id             Int      @id @default(autoincrement())
  userId         String?
  userIp         String
  searchQuery    String
  latitude       Float
  longitude      Float
  weatherResult  String
  temperature    Float
  createdAt      DateTime @default(now())
}
